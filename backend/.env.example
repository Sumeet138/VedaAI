# ----- Server -----
PORT=4000
NODE_ENV=development

# ----- Datastores -----
MONGODB_URI=mongodb://localhost:27017/vedaai
REDIS_URL=redis://localhost:6379

# ----- AI providers -----
# Gemini — primary or fallback LLM provider.
# Get a free key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Standard sections (MCQ, true/false, fill-blank, short-answer)
GEMINI_MODEL=gemini-2.5-flash
# Complex sections (numerical, long-answer, diagram)
# Upgrade to gemini-2.5-pro once GCP billing is linked for better math quality.
GEMINI_MODEL_MATH=gemini-2.5-flash

# Groq — primary or fallback LLM provider (large free-tier quota).
# Get a free key: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
# Reasoning model used on complex sections. Falls back through the chain in groq.service.ts
# if a model is decommissioned. Current models: https://console.groq.com/docs/models
GROQ_REASONING_MODEL=openai/gpt-oss-120b

# ----- LLM Provider routing -----
# Switch primary/fallback with these two vars — no code changes needed.
# Options: groq | gemini
LLM_PRIMARY=groq
# Options: groq | gemini | none
LLM_FALLBACK=gemini

# ----- Auth -----
# All /api/v1 routes require X-API-Key: <value> header when this is set.
# Leave blank to disable in dev. Generate with: openssl rand -hex 32
VEDA_API_KEY=

# ----- CORS / Puppeteer -----
CORS_ORIGIN=http://localhost:3000
# Used by Puppeteer to navigate to the bare /print/{id} route for PDF rendering
FRONTEND_URL=http://localhost:3000

# ----- Worker tuning -----
WORKER_CONCURRENCY=2
MAX_FILE_SIZE_MB=10
